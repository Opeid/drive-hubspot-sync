# Google Drive
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json   # path to your downloaded service account JSON
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here               # ID of the Drive folder to watch

# Webhook
WEBHOOK_URL=https://your-public-domain.com/webhook/drive  # publicly accessible URL (ngrok for local dev)
PORT=3000

# HubSpot
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here
